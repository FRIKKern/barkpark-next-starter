# Barkpark connection — `npm run new-project <name>` writes these into .env.local for you.
# All server-side (no NEXT_PUBLIC_ on the token → never bundled to the browser).

# Barkpark base URL (browser-exposed; SSR + client). Local: http://localhost:4000
NEXT_PUBLIC_API_URL=https://api.barkpark.cloud
# Server-side read token (Bearer on every SSR fetch).
BARKPARK_READ_TOKEN=
# The project this app reads (created in the default workspace by new-project).
BARKPARK_WORKSPACE=default
BARKPARK_PROJECT=
BARKPARK_DATASET=production
